#!/usr/bin/env python3
"""Claim an agent name in the C3PO coordinator.

Derives the machine name from local config (same logic as hook scripts),
registers the agent to get the actual assigned agent_id (accounting for any
collision suffix), then immediately marks it offline via unregister?keep=true
so the real agent's SessionStart hook can re-register without collision.

Usage:
    c3po-claim-name <project_name>
    agent_id=$(c3po-claim-name myproject)

Prints the assigned agent_id to stdout. Diagnostic messages go to stderr.
Exit 0 on success, non-zero on failure.

This implements the "cold start / wait_first" pattern documented in
docs/watcher-pattern.md. It is idempotent: if an offline entry already
exists, register updates it in-place and unregister?keep=true is a no-op.
"""
from __future__ import annotations

import json
import os
import platform
import re
import ssl
import sys
import urllib.error
import urllib.request

CREDENTIALS_FILE = os.path.expanduser("~/.claude/c3po-credentials.json")
_AGENT_ID_SAFE = re.compile(r"[^a-zA-Z0-9_./-]")


def sanitize_name(name: str) -> str:
    result = _AGENT_ID_SAFE.sub("-", name)
    while "--" in result:
        result = result.replace("--", "-")
    return result.strip("-")


def get_machine_name() -> str:
    if machine_name := os.environ.get("C3PO_MACHINE_NAME"):
        return machine_name

    claude_json = os.path.expanduser("~/.claude.json")
    try:
        with open(claude_json) as f:
            config = json.load(f)
        mcp_servers = config.get("mcpServers", {})
        c3po_config = mcp_servers.get("c3po", {})
        headers = c3po_config.get("headers", {})
        header_value = headers.get("X-Machine-Name", "")
        if header_value:
            match = re.match(r'\$\{[^:}]+:-([^}]+)\}', header_value)
            if match:
                return match.group(1)
            if not header_value.startswith("$"):
                return header_value
    except (FileNotFoundError, json.JSONDecodeError, KeyError):
        pass

    return platform.node().split(".")[0]


def get_credentials() -> dict:
    try:
        with open(CREDENTIALS_FILE) as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError, PermissionError):
        return {}


def get_api_token(creds: dict) -> str:
    token = creds.get("api_token", "")
    if not token:
        ss = creds.get("server_secret", "")
        ak = creds.get("api_key", "")
        if ss and ak:
            token = f"{ss}.{ak}"
    return token


def make_ssl_context() -> ssl.SSLContext | None:
    ca_cert = os.environ.get("C3PO_CA_CERT")
    if ca_cert:
        ctx = ssl.create_default_context()
        ctx.load_verify_locations(ca_cert)
        return ctx
    return None


def api_post(url: str, headers: dict, ssl_ctx) -> dict:
    req = urllib.request.Request(url, data=b"", method="POST")
    for k, v in headers.items():
        req.add_header(k, v)
    try:
        with urllib.request.urlopen(req, context=ssl_ctx, timeout=15) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")
        raise RuntimeError(f"HTTP {e.code}: {body}") from e


def main() -> int:
    if len(sys.argv) != 2 or sys.argv[1] in ("-h", "--help"):
        print("Usage: c3po-claim-name <project_name>", file=sys.stderr)
        print("Prints the assigned agent_id to stdout.", file=sys.stderr)
        return 1 if len(sys.argv) != 2 else 0

    project_name = sanitize_name(sys.argv[1])
    if not project_name:
        print("Error: project_name is empty after sanitization", file=sys.stderr)
        return 1

    creds = get_credentials()
    if not creds:
        print(f"Error: Credentials file not found: {CREDENTIALS_FILE}", file=sys.stderr)
        print("Run setup.py --enroll to configure credentials.", file=sys.stderr)
        return 1

    coordinator_url = creds.get("coordinator_url", "http://localhost:8420").rstrip("/")
    api_token = get_api_token(creds)
    if not api_token:
        print("Error: No api_token found in credentials", file=sys.stderr)
        return 1

    machine_name = sanitize_name(get_machine_name())
    ssl_ctx = make_ssl_context()

    auth_headers = {"Authorization": f"Bearer {api_token}"}

    # Step 1: Register to get the actual assigned agent_id
    print(f"Registering {machine_name}/{project_name} ...", file=sys.stderr)
    try:
        result = api_post(
            f"{coordinator_url}/agent/api/register",
            {**auth_headers, "X-Machine-Name": machine_name, "X-Project-Name": project_name},
            ssl_ctx,
        )
    except RuntimeError as e:
        print(f"Error: Registration failed: {e}", file=sys.stderr)
        return 1

    agent_id = result.get("id")
    if not agent_id:
        print(f"Error: Unexpected response from register: {result}", file=sys.stderr)
        return 1

    if agent_id != f"{machine_name}/{project_name}":
        print(f"Warning: collision detected — assigned {agent_id!r} instead of {machine_name}/{project_name!r}", file=sys.stderr)

    # Step 2: Mark offline immediately so SessionStart can re-register without collision
    print(f"Marking {agent_id} offline (keep=true) ...", file=sys.stderr)
    try:
        api_post(
            f"{coordinator_url}/agent/api/unregister?keep=true",
            {**auth_headers, "X-Machine-Name": agent_id},
            ssl_ctx,
        )
    except RuntimeError as e:
        print(f"Error: unregister?keep=true failed: {e}", file=sys.stderr)
        return 1

    print(agent_id)
    return 0


if __name__ == "__main__":
    sys.exit(main())
