# C3PO Production Environment Variables
# Copy this file to .env and fill in values.
# .env is gitignored — secrets must never be committed.

# --- Coordinator ---
C3PO_SERVER_SECRET=    # Bearer token prefix for /agent/* and /admin/* auth
C3PO_ADMIN_KEY=         # Admin key for /admin/* endpoints
C3PO_PROXY_BEARER_TOKEN=  # Shared secret between nginx and mcp-auth-proxy

# --- Redis ---
REDIS_PASSWORD=         # Redis AUTH password (generate: openssl rand -base64 32)

# --- OAuth (mcp-auth-proxy) ---
# Create a GitHub OAuth App: Settings > Developer settings > OAuth Apps
# Callback URL: https://<your-domain>/.auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ALLOWED_USER=   # GitHub username(s) allowed to authenticate (comma-separated)
